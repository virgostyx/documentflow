<div class="rounded-md border border-gray-200 p-3" data-workflow-builder-target="step">
  <%= f.hidden_field :id %>
  <%= f.hidden_field :order, data: { workflow_builder_target: "order" } %>
  <%= f.hidden_field :_destroy, data: { workflow_builder_target: "destroy" } %>

  <div class="flex flex-wrap items-center gap-3">
    <span class="drag-handle cursor-grab text-gray-400" title="Drag to reorder">&#10495;</span>

    <%= f.select :role, WorkflowStep::ROLES.map { |role| [ role, role ] }, {},
                 class: "rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>

    <%= f.collection_select :actor_id, @entity_members, :id, :email, { include_blank: "Select an actor..." },
                            class: "min-w-0 flex-1 rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>

    <button type="button" data-action="workflow-builder#removeStep"
            class="text-sm text-danger-600 hover:text-danger-700 whitespace-nowrap">
      Remove
    </button>
  </div>

  <div class="mt-3 flex flex-wrap items-center gap-3">
    <label class="flex items-center gap-2 text-sm text-gray-600 whitespace-nowrap">
      <%= f.check_box :is_parallel, class: "rounded border-gray-300 text-primary-600 focus:ring-primary-500" %>
      Parallel step
    </label>

    <label class="flex items-center gap-2 text-sm text-gray-600 whitespace-nowrap">
      Group
      <%= f.number_field :parallel_group, min: 1,
                         class: "w-20 rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" %>
    </label>
  </div>
</div>

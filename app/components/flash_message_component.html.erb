<div class="relative overflow-hidden flex items-start gap-3 w-full rounded-lg border <%= config[:bg] %> <%= config[:border] %> <%= config[:text] %> shadow-lg px-4 py-3 animate-[slide-down_0.3s_ease-out]"
     data-controller="flash"
     data-flash-duration-value="<%= duration %>"
     data-action="mouseenter->flash#pause mouseleave->flash#resume"
     role="alert">
  <div class="flex-shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-full <%= config[:icon_bg] %> <%= config[:icon_color] %>">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= config[:icon_path] %>"/>
    </svg>
  </div>

  <p class="flex-1 text-sm font-medium pt-1.5"><%= message %></p>

  <button type="button" data-action="click->flash#close" class="flex-shrink-0 <%= config[:text] %> hover:opacity-70 transition-opacity pt-1.5">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>

  <div class="absolute bottom-0 left-0 h-1 w-full <%= config[:progress] %>" data-flash-target="progress"></div>
</div>

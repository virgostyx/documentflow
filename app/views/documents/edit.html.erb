<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <%= render Ui::PageHeaderComponent.new(
    title: "Edit document",
    description: current_entity.name,
    back_path: entity_document_path(current_entity, @document),
    back_text: @document.reference_number
  ) %>

  <%= render Ui::CardComponent.new do %>
    <%= render "form", document: @document %>
  <% end %>
</div>

<%= form_with model: [ current_entity, contact ], builder: FloatingLabelsRails::FormBuilder, local: true do |f| %>
  <% if contact.errors.any? %>
    <div class="mb-4 rounded-md bg-danger-50 border border-danger-200 px-4 py-3 text-sm text-danger-700">
      <%= contact.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <%= f.floating_text_field :first_name, label: "First name", required: true, autofocus: true, placeholder: " " %>
    <%= f.floating_text_field :last_name, label: "Last name", required: true, placeholder: " " %>
  </div>

  <%= f.floating_email_field :email, label: "Email", required: true, placeholder: " " %>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <%= f.floating_text_field :company, label: "Company", placeholder: " " %>
    <%= f.floating_text_field :phone, label: "Phone", placeholder: " " %>
  </div>

  <div class="mt-6 flex justify-end gap-3">
    <%= render(Ui::ButtonComponent.new(href: entity_contacts_path(current_entity), variant: :secondary)) { "Cancel" } %>
    <%= render(Ui::ButtonComponent.new) { contact.persisted? ? "Save changes" : "Create contact" } %>
  </div>
<% end %>

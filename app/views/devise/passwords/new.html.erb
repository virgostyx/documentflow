<%= render Auth::AuthLayoutComponent.new(
  title: "Mot de passe oublié ?",
  subtitle: "Saisissez votre e-mail pour recevoir les instructions"
) do %>
  <div class="mb-6">
    <%= link_to new_user_session_path, class: "inline-flex items-center text-sm font-medium text-gray-600 hover:text-primary-600 transition-colors" do %>
      ← Retour à la connexion
    <% end %>
  </div>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name),
               html: { method: :post },
               builder: FloatingLabelsRails::FormBuilder) do |f| %>

    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="mb-6 p-4 rounded-lg bg-blue-50 border border-blue-200">
      <p class="text-sm text-blue-800">
        📧 Nous vous enverrons un e-mail avec les instructions pour réinitialiser votre mot de passe.
      </p>
    </div>

    <%# Email %>
    <%= f.floating_email_field :email,
                               label: "Adresse e-mail",
                               required: true,
                               autofocus: true,
                               autocomplete: "email",
                               placeholder: " " %>

    <%# Bouton %>
    <%= f.submit "Envoyer les instructions",
                 class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-colors" %>

    <%# Liens %>
    <div class="mt-6 text-center text-sm">
      <p class="text-gray-600">
        Vous vous souvenez de votre mot de passe ?
        <%= link_to "Se connecter", new_user_session_path, class: "font-medium text-primary-600 hover:text-primary-500" %>
      </p>
    </div>

    <div class="mt-3 text-center text-sm">
      <p class="text-gray-600">
        Pas encore de compte ?
        <%= link_to "Créer un compte", new_user_registration_path, class: "font-medium text-primary-600 hover:text-primary-500" %>
      </p>
    </div>

    <div class="mt-8 pt-6 border-t border-gray-200">
      <div class="text-center text-xs text-gray-500">
        <p>🔒 Le lien de réinitialisation expire au bout de 6 heures pour des raisons de sécurité</p>
      </div>
    </div>
  <% end %>
<% end %>

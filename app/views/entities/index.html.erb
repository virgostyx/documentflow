<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <%= render Ui::PageHeaderComponent.new(
    title: "My entities",
    description: "Organizations you belong to",
    back_path: dashboard_path,
    back_text: "Dashboard"
  ) %>

  <div class="flex justify-end mb-4">
    <%= render(Ui::ButtonComponent.new(href: new_entity_path)) { "New entity" } %>
  </div>

  <% if @entities.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @entities.each do |entity| %>
        <%= render Entities::EntityCardComponent.new(entity: entity, current_user: current_user) %>
      <% end %>
    </div>
  <% else %>
    <%= render Ui::EmptyStateComponent.new(
      title: "No entities yet",
      description: "Create an entity to start managing your documents."
    ) do |empty_state| %>
      <% empty_state.with_action do %>
        <%= render(Ui::ButtonComponent.new(href: new_entity_path)) { "New entity" } %>
      <% end %>
    <% end %>
  <% end %>
</div>

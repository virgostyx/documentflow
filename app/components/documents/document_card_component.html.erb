<%= link_to entity_document_path(document.entity, document), class: "block bg-white rounded-lg shadow-md border border-gray-200 p-6 hover:border-primary-300 hover:shadow-lg transition-all" do %>
  <div class="flex items-start justify-between gap-3">
    <div>
      <p class="text-sm text-gray-500"><%= document.reference_number %></p>
      <h3 class="font-semibold text-gray-900"><%= document.subject %></h3>
    </div>

    <%= render Documents::DocumentStatusBadgeComponent.new(status: document.status) %>
  </div>

  <p class="mt-4 text-sm text-gray-500">
    <%= document.sender&.full_name %> &rarr; <%= document.addressee&.full_name %>
  </p>
<% end %>

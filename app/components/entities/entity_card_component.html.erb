<%= link_to entity_path(entity), class: "block bg-white rounded-lg shadow-md border border-gray-200 p-6 hover:border-primary-300 hover:shadow-lg transition-all" do %>
  <div class="flex items-start justify-between gap-3">
    <div>
      <h3 class="text-lg font-semibold text-gray-900"><%= entity.name %></h3>
      <p class="mt-1 text-sm text-gray-500"><%= entity.code %></p>
    </div>

    <% if role_label %>
      <%= render(Ui::BadgeComponent.new(color: role_color)) { role_label } %>
    <% end %>
  </div>

  <p class="mt-4 text-sm text-gray-500">
    <%= pluralize(entity.entity_users.active.count, "member") %>
  </p>
<% end %>

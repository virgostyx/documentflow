<% content_for :title, "Link unavailable - DocumentFlow" %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="flex items-center gap-2 mb-8">
    <svg class="w-8 h-8 text-primary-600" fill="currentColor" viewBox="0 0 24 24">
      <path d="M3 3h8v8H3V3zm10 0h8v8h-8V3zM3 13h8v8H3v-8zm10 0h8v8h-8v-8z"/>
    </svg>
    <span class="text-xl font-bold text-gray-900">DocumentFlow</span>
  </div>

  <%= render Ui::CardComponent.new do %>
    <%= render Ui::EmptyStateComponent.new(
      title: "This link is no longer available",
      description: "The share link you followed has expired or does not exist. Please ask the sender for a new link."
    ) %>
  <% end %>
</div>

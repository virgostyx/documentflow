<%= render Auth::AuthLayoutComponent.new(
  title: "Connexion",
  subtitle: "Heureux de vous revoir sur DocumentFlow"
) do %>
  <div class="mb-6">
    <%= link_to root_path, class: "inline-flex items-center text-sm font-medium text-gray-600 hover:text-primary-600 transition-colors" do %>
      ← Retour à l'accueil
    <% end %>
  </div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name),
               builder: FloatingLabelsRails::FormBuilder) do |f| %>

    <%# Email %>
    <%= f.floating_email_field :email,
                               label: "Adresse e-mail",
                               required: true,
                               autocomplete: "email",
                               autofocus: true,
                               placeholder: " " %>

    <%# Mot de passe %>
    <%= f.floating_password_field :password,
                                  label: "Mot de passe",
                                  required: true,
                                  autocomplete: "current-password",
                                  placeholder: " " %>

    <%# Se souvenir de moi %>
    <div class="flex items-center justify-between mb-6">
      <% if devise_mapping.rememberable? %>
        <label class="flex items-center cursor-pointer">
          <%= f.check_box :remember_me,
                          class: "h-4 w-4 text-primary-600 focus:ring-primary-500 border-gray-300 rounded" %>
          <span class="ml-2 text-sm text-gray-700">Se souvenir de moi</span>
        </label>
      <% end %>

      <%= link_to "Mot de passe oublié ?", new_user_password_path,
                  class: "text-sm font-medium text-primary-600 hover:text-primary-500" %>
    </div>

    <%# Bouton %>
    <%= f.submit "Se connecter",
                 class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-colors" %>

    <%# Liens %>
    <div class="mt-6 text-center text-sm">
      <p class="text-gray-600">
        Pas encore de compte ?
        <%= link_to "Créer un compte gratuitement", new_user_registration_path,
                    class: "font-medium text-primary-600 hover:text-primary-500" %>
      </p>
    </div>

    <div class="mt-8 pt-6 border-t border-gray-200">
      <div class="text-center text-xs text-gray-500">
        <p>🔒 Connexion sécurisée par chiffrement SSL</p>
      </div>
    </div>
  <% end %>
<% end %>
